# 📦 Dependency directories
node_modules/
**/node_modules/
jspm_packages/
.npm/

# 🏗️ Build and compile outputs
dist/
**/dist/
build/
**/build/
out/
.out/
.next/
.nuxt/
.docusaurus/
.cache/
.vite/
.parcel-cache/
.turbo/
coverage/
.tmp/
temp/
tmp/

# 🖼️ User uploads & dynamic runtime assets (receipts, files, etc.)
uploads/
**/uploads/
backend/uploads/
frontend/src/assets/uploads/

# 🚦 Log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
logs/
**/logs/

# 🔑 Secrets and Local Environment Files
.env
.env.*
!.env.example

# 🛠️ Editor & IDE configurations (VS Code, WebStorm/IntelliJ, etc.)
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.project
.classpath
.settings/

# 🖥️ System & OS metadata
.DS_Store
Thumbs.db
desktop.ini

# 🐍 Python / FastAPI specific ignores
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.pytest_cache/
.ipynb_checkpoints/
