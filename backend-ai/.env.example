# Credenziali del Database (Usa "localhost" se avvii uvicorn localmente, oppure "mysql" se usi Docker)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=businesstravel

# Chiave JWT (Deve essere identica a quella impostata in backend/.env)
JWT_SECRET=your_jwt_secret_key_here

# Chiave API di Mistral AI (Indispensabile per far funzionare l'agente IA)
MISTRAL_API_KEY=your_mistral_api_key_here
